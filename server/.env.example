# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# docker compose up -d → postgres://postgres:postgres@localhost:5432/appdb
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appdb"

# Used by Prisma Accelerate or direct connections (same as DATABASE_URL if no pooler)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/appdb"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Frontend URL allowed to make requests
CORS_ORIGIN="http://localhost:5173"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 64
JWT_SECRET=""

# Token expiration in seconds (86400 = 1 day)
JWT_EXPIRES_IN=86400

# ─── Password Hashing ────────────────────────────────────────────────────────
# bcrypt salt rounds (10 = recommended minimum, 12 = more secure, slower)
SALT_ROUNDS=10

# ─── Swagger (API Docs) ──────────────────────────────────────────────────────
# Basic auth credentials for /api-docs route
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin
